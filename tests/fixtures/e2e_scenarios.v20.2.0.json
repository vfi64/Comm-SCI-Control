{
  "version": "20.2.0",
  "artifact_type": "operational",
  "scenarios": [
    {
      "id": "help_command_coverage",
      "description": "Comm Help should expose the command surface with canonical tokens.",
      "input": "Comm Help",
      "required_tokens": [
        "Comm Start",
        "Comm State",
        "Comm Validate",
        "Profile Expert",
        "SCI on",
        "Color on"
      ],
      "min_token_hits": 5,
      "required_regex": [],
      "min_regex_hits": 0,
      "forbidden_regex": []
    },
    {
      "id": "invalid_control_command_rejection",
      "description": "Control on should not be accepted as a canonical command token.",
      "input": "Control on",
      "required_tokens": [
        "Control on"
      ],
      "min_token_hits": 1,
      "required_regex": [
        "(not|no|unknown|invalid|undefined|nicht|kein)[\\s\\S]{0,60}(command|token|canonical|kanonisch|kommando|definiert)"
      ],
      "min_regex_hits": 1,
      "forbidden_regex": [
        "(control\\s+on)[\\s\\S]{0,40}(enabled|activated|ok|accepted)"
      ]
    },
    {
      "id": "anchor_command_response",
      "description": "Comm Anchor should mention anchor snapshot semantics.",
      "input": "Comm Anchor",
      "required_tokens": [
        "Comm Anchor"
      ],
      "min_token_hits": 1,
      "required_regex": [
        "(anchor)[\\s\\S]{0,60}(snapshot|state|session)"
      ],
      "min_regex_hits": 1,
      "forbidden_regex": []
    }
  ]
}
